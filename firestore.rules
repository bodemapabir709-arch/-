rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "dcrofiq@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidDoctor() {
      return hasOnlyAllowedFields(['name', 'specialization', 'bio', 'imageUrl', 'createdAt']) &&
             isValidString('name', 1, 100) &&
             isValidString('specialization', 1, 100) &&
             isValidString('bio', 1, 1000) &&
             isValidUrl(request.resource.data.imageUrl) &&
             request.resource.data.createdAt is number;
    }

    function isValidService() {
      return hasOnlyAllowedFields(['title', 'description', 'imageUrl', 'createdAt']) &&
             isValidString('title', 1, 100) &&
             isValidString('description', 1, 1000) &&
             isValidUrl(request.resource.data.imageUrl) &&
             request.resource.data.createdAt is number;
    }

    function isValidTestimonial() {
      return hasOnlyAllowedFields(['patientName', 'feedback', 'rating', 'createdAt']) &&
             isValidString('patientName', 1, 100) &&
             isValidString('feedback', 1, 1000) &&
             request.resource.data.rating is number &&
             request.resource.data.rating >= 1 && request.resource.data.rating <= 5 &&
             request.resource.data.createdAt is number;
    }

    function isValidUser() {
      return hasOnlyAllowedFields(['email', 'role', 'createdAt']) &&
             request.resource.data.email is string &&
             request.resource.data.role in ['admin', 'patient'] &&
             request.resource.data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /doctors/{doctorId} {
      allow read: if true;
      allow create: if isAdmin() && isValidDoctor();
      allow update: if isAdmin() && isValidDoctor() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAdmin() && isValidService();
      allow update: if isAdmin() && isValidService() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidTestimonial();
      allow update: if isAdmin() && isValidTestimonial() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser() && 
                    ((request.resource.data.role == 'patient') || isAdmin());
      allow update: if isAuthenticated() && isValidUser() && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin()) &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }
  }
}
